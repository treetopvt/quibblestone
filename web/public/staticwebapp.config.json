{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/admin.html",
      "/assets/*",
      "/*.svg",
      "/*.jpg",
      "/*.jpeg",
      "/*.png",
      "/*.ico",
      "/*.webmanifest",
      "/*.txt",
      "/*.xml",
      "/*.json"
    ]
  }
}
