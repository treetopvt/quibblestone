{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    { "route": "/admin", "rewrite": "/admin.html" },
    { "route": "/admin/*", "rewrite": "/admin.html" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/admin.html",
      "/assets/*",
      "/*.svg",
      "/*.jpg",
      "/*.jpeg",
      "/*.png",
      "/*.ico",
      "/*.webmanifest",
      "/*.txt",
      "/*.xml",
      "/*.json"
    ]
  }
}
